# ── JPredict — Environment Variables ────────────────────────────────────────
#
# LOCAL DEVELOPMENT
#   Copy this to .env.local and fill in values.
#
# VERCEL DEPLOYMENT
#   Add these in: Vercel Dashboard → Your Project → Settings → Environment Variables
#   Do NOT commit .env.local to git.
#
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — Your football-data.org API token
# Get it from: https://www.football-data.org (free tier is fine)
FOOTBALL_DATA_API_KEY=your_token_here

# OPTIONAL — Confidence threshold below which predictions are discarded (default: 80)
MIN_CONFIDENCE=80

# OPTIONAL — Max predictions shown per match (default: 3)
MAX_PREDICTIONS=3

# OPTIONAL — Comma-separated league codes to analyze (default: PL,PD,BL1,SA,FL1)
# Available: PL, PD, BL1, SA, FL1, CL, DED, PPL, ELC
ACTIVE_LEAGUES=PL,PD,BL1,SA,FL1

# OPTIONAL — Only set this if you're running a SEPARATE Express backend
# Leave it empty (or delete it) to use the built-in Next.js API routes
# NEXT_PUBLIC_API_URL=http://localhost:4000
